{
  "name": "z3rsim",
  "version": "8.0.0",
  "description": "Z3R Simulator - Zelda: A Link to the Past Randomizer Simulator",
  "license": "ISC",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration=development",
    "build": "ng build",
    "build:dev": "ng build --configuration=development",
    "build:prod": "ng build --prod",
    "serve:dist": "npx serve dist -l 8000",
    "preinstall": "npx npm-force-resolutions",
    "postinstall": "echo 'skipping ngcc'"
  },
  "resolutions": {
    "spdy": "4.0.2"
  },
  "dependencies": {
    "@angular/animations": "^20.3.21",
    "@angular/common": "^20.3.21",
    "@angular/compiler": "^20.3.21",
    "@angular/core": "^20.3.21",
    "@angular/forms": "^20.3.21",
    "@angular/platform-browser": "^20.3.21",
    "@angular/platform-browser-dynamic": "^20.3.21",
    "@angular/router": "^20.3.21",
    "bootstrap": "3.3.7",
    "core-js": "3.21.1",
    "ngx-bootstrap": "^18.0.0",
    "rxjs": "~7.8.0",
    "rxjs-compat": "6.6.7",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.26",
    "@angular/cli": "^20.3.26",
    "@angular/compiler-cli": "^20.3.21",
    "typescript": "~5.8.3"
  }
}
