{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "project": {
    "name": "z3rsim"
  },
  "apps": [
    {
      "root": "src",
      "outDir": "dist",
      "assets": [
        { "glob": "**/*", "input": "../assets", "output": "./assets" },
        { "glob": "**/*", "input": "../hotfix", "output": "./hotfix" },
        { "glob": "**/*", "input": "../fonts", "output": "./fonts" },
        { "glob": "jquery-3.3.1.min.js", "input": "..", "output": "./" },
        { "glob": "bootstrap.min.js", "input": "..", "output": "./" },
        { "glob": "font-awesome.min.css", "input": "..", "output": "./" },
        { "glob": "hammersmith-one.css", "input": "..", "output": "./" },
        { "glob": "manifest.json", "input": "..", "output": "./" },
        { "glob": "404.html", "input": "..", "output": "./" },
        { "glob": "map.png", "input": "..", "output": "./" },
        { "glob": "twitch_glitch_icon.png", "input": "..", "output": "./" }
      ],
      "index": "index.html",
      "main": "main.ts",
      "polyfills": "polyfills.ts",
      "tsconfig": "tsconfig.json",
      "prefix": "app",
      "styles": [
        "../node_modules/bootstrap/dist/css/bootstrap.min.css",
        "styles.css"
      ],
      "scripts": [],
      "environmentSource": "environments/environment.ts",
      "environments": {
        "dev": "environments/environment.ts",
        "prod": "environments/environment.prod.ts"
      }
    }
  ]
}
