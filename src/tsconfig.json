{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "types": [],
    "strict": false,
    "noImplicitAny": false,
    "allowUnreachableCode": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "src/environments/environment.prod.ts"]
}
